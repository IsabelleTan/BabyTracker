# Generate a strong random key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Comma-separated list of allowed frontend origins
# Development: http://localhost:5173
# Production: https://yourdomain.com
CORS_ORIGINS=http://localhost:5173

# Path to the SQLite database file
# Development default: sqlite+aiosqlite:///./babytracker.db
# Production: use an absolute path outside the app directory, e.g.:
# DATABASE_URL=sqlite+aiosqlite:////srv/babytracker/data/babytracker.db
DATABASE_URL=sqlite+aiosqlite:///./babytracker.db
